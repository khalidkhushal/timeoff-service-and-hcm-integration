{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "(src/.*\\.spec\\.ts$|test/.*\\.e2e-spec\\.ts$)",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "collectCoverageFrom": [
    "src/**/*.(t|j)s",
    "!src/main.ts"
  ],
  "coverageDirectory": "coverage",
  "testEnvironment": "node"
}
